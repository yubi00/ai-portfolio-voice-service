OPENAI_API_KEY=sk-...
PORT=3001
NODE_ENV=development

# Cost guards — all optional, defaults shown below.
# Hard cap per session regardless of activity (milliseconds).
MAX_SESSION_DURATION_MS=300000   # 5 minutes
# Close session after this much browser silence (milliseconds).
INACTIVITY_TIMEOUT_MS=30000      # 30 seconds
# Max simultaneous OpenAI WS sessions.
MAX_CONCURRENT_SESSIONS=3

# Comma-separated allowed origins. Leave empty to allow all (dev only).
# Example: ALLOWED_ORIGINS=https://yubi.dev,https://www.yubi.dev
ALLOWED_ORIGINS=
