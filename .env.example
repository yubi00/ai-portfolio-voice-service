OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VOICE=echo
GITHUB_TOKEN=your_github_token_for_sync_only
GITHUB_USERNAME=yubi00
PORT=3001
NODE_ENV=development
VOICE_MODE=realtime
REQUIRE_AUTH=false
AUTH_SIGNING_SECRET=
VOICE_AUTH_QUERY_PARAM=access_token

# Turn-based mode defaults (used when VOICE_MODE=turn-based)
TURN_BASED_TRANSCRIPTION_MODEL=whisper-1
TURN_BASED_CHAT_MODEL=gpt-4o-mini
TURN_BASED_TTS_MODEL=gpt-4o-mini-tts
TURN_BASED_SILENCE_THRESHOLD=0.015
TURN_BASED_SILENCE_DURATION_MS=450
TURN_BASED_MIN_SPEECH_DURATION_MS=180
TURN_BASED_PCM_CHUNK_BYTES=4800
TURN_BASED_MAX_HISTORY_MESSAGES=8

# Cost guards. Values below match the current application defaults.
# Hard cap per session regardless of activity, in milliseconds.
MAX_SESSION_DURATION_MS=300000
# Close session after this much browser silence, in milliseconds.
INACTIVITY_TIMEOUT_MS=30000
# Max simultaneous OpenAI WebSocket sessions.
MAX_CONCURRENT_SESSIONS=3

# WebSocket abuse controls.
WS_MAX_MESSAGE_BYTES=262144
WS_CONNECT_RATE_LIMIT=12
WS_CONNECT_RATE_WINDOW_MS=60000
WS_CONTROL_RATE_LIMIT=120
WS_CONTROL_RATE_WINDOW_MS=60000

# Comma-separated allowed origins. Leave empty to allow all (dev only).
# Example: ALLOWED_ORIGINS=https://yubi.dev,https://www.yubi.dev
ALLOWED_ORIGINS=
